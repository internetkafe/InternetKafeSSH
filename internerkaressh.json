{
  "log": {
    "loglevel": "info"
  },
  "dns": {
    "servers": [
      {
        "address": "fakedns",
        "domains": [
          "all"
        ]
      }
    ]
  },
  "inbounds": [
    {
      "tag": "internetkafessh",
      "port": 22,
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": [
          "fakedns",
          "http",
          "tls",
          "quic"
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "none"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "rules": [
      {
        "ip": [
          "198.18.0.0/15"
        ],
        "type": "field",
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "block"
      }
    ],
    "domainStrategy": "IPIfNonMatch"
  },
  "policy": {
    "levels": {
      "0": {
        "connIdle": 300,
        "handshake": 4,
        "bufferSize": 512,
        "uplinkOnly": 5,
        "downlinkOnly": 30
      }
    },
    "system": {
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "finalmask": {
    "tcp": [
      {
        "type": "header-custom",
        "settings": {
          "clients": [],
          "servers": [
            [
              {
                "type": "str",
                "packet": "SSH-2.0-OpenSSH_9.9p1 Debian-13\r\n"
              },
              {
                "type": "hex",
                "packet": ""
              },
              {
                "type": "hex",
                "packet": "0000000c15000000000000000000000000000000"
              }
            ]
          ]
        }
      }
    ]
  }
}
